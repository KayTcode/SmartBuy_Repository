{
  "name": "smartbuy-be",
  "version": "1.0.0",
  "type": "module",
  "description": "SmartBuy RESTful API Server",
  "main": "api/index.js",
  "scripts": {
    "start": "node api/index.js",
    "dev": "nodemon api/index.js",
    "vercel-dev": "vercel dev",
    "deploy": "vercel --prod",
    "seed:categories": "node scripts/seedCategories.js",
    "seed:products": "node scripts/seedProducts.js",
    "seed:admin": "node scripts/seedAdmin.js",
    "seed:all": "node scripts/seedCategories.js && node scripts/seedProducts.js && node scripts/seedAdmin.js"
  },
  "keywords": [
    "nodejs",
    "restful",
    "api",
    "express",
    "mongodb",
    "vercel"
  ],
  "author": "F-Manifest Team",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "google-auth-library": "^9.14.0",
    "http-errors": "^2.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.10.1",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}